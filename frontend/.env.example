# ============================================================
# Na Gaveta — Frontend — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# Variáveis VITE_ são expostas ao browser
# ============================================================

# URL da API (em dev, o proxy do Vite redireciona /api para o backend)
# Em produção, aponte para o domínio real da API
VITE_API_URL=/api

# Nome do app (opcional, para personalização)
VITE_APP_NAME=Na Gaveta
